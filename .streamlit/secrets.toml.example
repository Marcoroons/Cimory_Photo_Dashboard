# Copy this file to secrets.toml and fill in your Supabase project values.
# secrets.toml is gitignored and must never be committed.
# Only the anon public key ships. Row-level security is the real boundary.
# The service role key must never appear here or in the deployed app.

SUPABASE_URL = "https://YOUR-PROJECT.supabase.co"
SUPABASE_ANON_KEY = "your-anon-public-key"

# Shared sign-up gate. New users must enter this code once when they sign up.
# Optional: the app defaults to "cimory123" if this is not set. Change it to
# rotate the code without touching code.
ADMIN_SIGNUP_CODE = "cimory123"
